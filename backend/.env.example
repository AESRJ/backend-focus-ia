# ============================================================
#  Focus IA — Variables de entorno (.env.example)
#  Copia este archivo como ".env" y rellena los valores reales.
# ============================================================

# --- Base de datos MySQL ---
# Formato: mysql+aiomysql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
#
# Ejemplos según proveedor:
#
#  Railway:
#    DATABASE_URL=mysql+aiomysql://root:password@containers-us-west-XX.railway.app:PUERTO/railway
#
#  PlanetScale:
#    DATABASE_URL=mysql+aiomysql://usuario:password@aws.connect.psdb.cloud/focusia?ssl_ca=/etc/ssl/certs/ca-certificates.crt
#
#  Aiven (MySQL):
#    DATABASE_URL=mysql+aiomysql://avnadmin:password@mysql-xxx.aivencloud.com:PUERTO/focusia?ssl_ca=/path/to/ca.pem
#
#  Local (desarrollo):
#    DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/focusia
DATABASE_URL=mysql+aiomysql://USUARIO:CONTRASEÑA@HOST:3306/focusia

# --- Secreto JWT ---
# Cadena aleatoria de al menos 32 bytes. Genera una nueva con:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CAMBIA_ESTE_SECRETO_POR_UNO_REAL
